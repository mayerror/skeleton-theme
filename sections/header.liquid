<header class="header full-width">
  <div class="container">
    <div class="header__inner">
      <!-- Mobile menu toggle -->
      <button class="header__menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger"></span>
        <span class="hamburger"></span>
        <span class="hamburger"></span>
      </button>
      <div class="header__inner-top">
        <div class="header__inner-left">
          {% if section.settings.logo_position == 'left' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-center">
          {% if section.settings.logo_position == 'center' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-right">
          {% if section.settings.logo_position == 'right' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
          <!-- Header icons -->
          <div class="header__icons">
            {% if section.settings.show_language_selector %}
              {% render 'language-selector' %}
            {% endif %}
            {% comment %}
              {% if section.settings.show_country_selector %}
                <div class="header__country-selector">
                  {% comment %} Country selector would go here {% endcomment %}
                  <select aria-label="Country/region selector">
                    <option value="US" selected>United States</option>
                    <option value="CA">Canada</option>
                    <option value="GB">United Kingdom</option>
                  </select>
                </div>
              {% endif %}
            {% endcomment %}

            {% if section.settings.show_account and shop.customer_accounts_enabled %}
              <a href="{{ routes.account_url }}" aria-label="Account" class="header__account-icon">
                {% render 'user-icon' %}
              </a>
            {% endif %}

            {% if section.settings.show_search %}
              <a href="{{ routes.search_url }}" aria-label="Search" class="header__search-icon">
                {% render 'search-icon' %}
              </a>
            {% endif %}

            <a href="{{ routes.cart_url }}" class="header__cart-link" aria-label="Shopping cart">
              {% if cart.item_count > 0 %}
                <span class="cart-count">{{ cart.item_count }}</span>
              {% endif %}
              {% render 'cart-icon' %}
            </a>
          </div>
        </div>
      </div>
      <div class="header__inner-bottom">
        <!-- Main navigation -->
        <nav class="header__navigation" role="navigation" aria-label="Main navigation">
          {% render 'header-menu', menu_handle: section.settings.menu %}
        </nav>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "select",
      "id": "menu_position",
      "label": "Menu position",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 0,
      "max": 500,
      "step": 20,
      "unit": "px",
      "label": "Logo width",
      "default": 200
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "label": "Mobile logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Utilities"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "Show language selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/region selector",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ]
}
{% endschema %}

{% style %}
  .header {
    background-color: var(--color-background-2, #333);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    color: var(--color-text, #222);
  }

  .header__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    display: flex;
    flex-direction: column;
    min-height: 80px;
  }

  .header__inner-top {
    display: flex;
  }

  .header__inner-left {
    flex: 1;
  }

  .header__inner-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .header__inner-bottom {
    display: flex;
    padding-top: 1rem;
    justify-content: {{ section.settings.menu_position }};
  }

  .header__logo-link {
    display: inline-block;
  }

  .header__logo-link:hover {
    opacity: 0.8;
  }

  .header__icons {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.6rem;
  }

  .header__icons a {
    /* color: var(--color-text, #222); */
    color: var(--color-text, #222);
  }

  .header__icons a:hover {
    color: var(--color-text-hover, #800020);
  }

  .header__icons .icon {
    width: 1.5rem;
    height: 1.5rem;
    display: inline-block;
    position: relative;
    cursor: pointer;
  }

  .header__cart-link {
    position: relative;
  }

  .cart-count {
    position: absolute;
    top: -2px;
    right: -2px;
    min-width: 20px;
    height: 20px;
    background-color: #030303;
    border: 1px solid #000000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    color: #fff;
    line-height: 1;
    padding: 0 2px;
    box-sizing: border-box;
    z-index: 10;
  }

  .header__language-selector,
  .header__country-selector {
    position: relative;
  }

  .chevron::after {
    content: '';
    position: absolute;
    right: 6px;
    top: -4px;
    bottom: 0;
    margin: auto;
    transform: rotate(45deg);
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    width: 6px;
    height: 6px;
    pointer-events: none;
  }

  .header__language-selector select,
  .header__country-selector select {
    background: transparent;
    border: none;
    outline: none;
    box-shadow: none;
    padding: 0.4rem 1.0rem 0.4rem 0.4rem;
    cursor: pointer;
    color: inherit;
    font-size: 14px;
    font-family: inherit;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  .header__language-selector select:hover,
  .header__country-selector select:hover {
    color: var(--color-text-hover, #800020);
    background-color: rgba(0, 0, 0, 0.04);
  }

  .header__language-selector option,
  .header__country-selector option {
    color: var(--color-text, #222);
    background-color: var(--color-background-1, #d6d6d6);
  }

  .header__language-selector option:hover,
  .header__country-selector option:hover {
    color: var(--color-text-hover, #800020);
    background-color: rgba(0, 0, 0, 0.04);
  }

  @media (max-width: 1200px) {
    .header .container {
      padding: 0 1rem;
    }
    .header .header__inner-left {
      flex: 0;
    }
  }

  .header__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 1001;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 3px;
    background-color: #333;
    margin: 5px 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    border-radius: 1px;
  }

  @media (max-width: 768px) {
    /* 1. Выстраиваем элементы шапки строго в один ряд */
    .header__inner-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: nowrap; /* Запрещаем перенос на новую строку */
      width: 100%;
    }

    /* Прячем левый пустой блок, чтобы логотип встал аккуратно */
    .header__inner-left {
      display: none;
    }

    .header__inner-center {
      flex: 1;
      display: flex;
      justify-content: flex-start; /* Логотип прижимается влево, как на макете */
    }

    .header__inner-right {
      flex: auto;
      display: flex;
      justify-content: flex-end;
    }

    /* Показываем кнопку бургера */
    .header__menu-toggle {
      display: flex;
      flex-direction: column;
      gap: 5px; /* Задаем фиксированный зазор вместо margin у полосок */
      padding: 5px;
      margin: 0;
    }

    .hamburger {
      margin: 0; /* Сбрасываем старый отступ */
    }

    /* 2. ПРЕВРАЩАЕМ НИЖНИЙ БЛОК В БОКОВУЮ ПАНЕЛЬ */
    .header__inner-bottom {
      position: fixed;
      top: 0;
      left: -100%; /* Полностью прячем панель за левый край экрана */
      width: 80%;  /* Занимает 80% ширины экрана, как на картинке */
      max-width: 340px;
      height: 100vh; /* Растягиваем на всю высоту экрана */
      background-color: #ffffff;
      box-shadow: 5px 0 15px rgba(0, 0, 0, 0.08);
      transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1); /* Плавное выезжание */
      padding: 100px 24px 40px 24px; /* Большой отступ сверху, чтобы меню не перекрывало верхний ряд */
      z-index: 999;
      display: flex;
      flex-direction: column;
      justify-content: flex-start !important;
    }

    /* Класс-активатор для открытия панели */
    .header__inner-bottom.active {
      left: 0; /* Выезжает на экран */
    }

    /* Показываем контейнер навигации внутри панели */
    .header__navigation {
      display: block; /* Сбрасываем display: none */
      position: static; /* Убираем абсолютное позиционирование */
      box-shadow: none;
      padding: 0;
      width: 100%;
    }

    /* Стилизация ссылок меню в мобильной панели */
    .header__navigation ul {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem; /* Дистанция между пунктами меню */
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .header__navigation a {
      font-size: 1.1rem;
      text-transform: uppercase; /* Все буквы заглавные как на макете */
      letter-spacing: 0.06em;
      color: var(--color-text, #222);
      text-decoration: none;
      display: block;
      width: 100%;
    }

    /* 3. АНИМАЦИЯ ИКОНКИ БУРГЕРА (КРЕСТИК) */
    .header__menu-toggle[aria-expanded="true"] .hamburger:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }
    .header__menu-toggle[aria-expanded="true"] .hamburger:nth-child(2) {
      opacity: 0;
    }
    .header__menu-toggle[aria-expanded="true"] .hamburger:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }
{% endstyle %}
