<header class="header full-width">
  <div class="container">
    <div class="header__inner">
      <!-- Mobile menu toggle -->
      <button class="header__menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger"></span>
        <span class="hamburger"></span>
        <span class="hamburger"></span>
      </button>
      <div class="header__inner-top">
        <div class="header__inner-left">
          {% if section.settings.logo_position == 'left' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-center">
          {% if section.settings.logo_position == 'center' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-right">
          {% if section.settings.logo_position == 'right' %}
            {% if section.settings.logo != blank %}
              <a href="{{ routes.root_url }}" class="header__logo-link">
                <img
                  src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                  alt="{{ section.settings.logo.alt | escape }}"
                  width="{{ section.settings.logo_width }}"
                  height="{{ section.settings.logo.height }}"
                  class="header__logo-image"
                >
              </a>
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
          <!-- Header icons -->
          <div class="header__icons">
            {% if section.settings.show_language_selector %}
              {% render 'language-selector' %}
              {% comment %}
                <div class="header__language-selector chevron">
                  {% comment %} Language selector would go here {% endcomment %}
                  <select aria-label="Language selector">
                    {% for locale in shop.published_locales %}
                      <option
                        value="{{ locale.iso_code }}"
                        {% if locale.iso_code == cart.locale.iso_code %}
                          selected
                        {% endif %}
                      >
                        {{ locale.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endcomment %}
            {% endif %}

            {% if section.settings.show_country_selector %}
              <div class="header__country-selector">
                {% comment %} Country selector would go here {% endcomment %}
                <select aria-label="Country/region selector">
                  <option value="US" selected>United States</option>
                  <option value="CA">Canada</option>
                  <option value="GB">United Kingdom</option>
                </select>
              </div>
            {% endif %}
            {% form 'localization' %}
              <!-- form content -->
            {% endform %}

            {% if section.settings.show_account and shop.customer_accounts_enabled %}
              <a href="{{ routes.account_url }}" aria-label="Account" class="header__account-icon">
                <img
                  src="{{ 'user.svg' | asset_url }}"
                  alt="User icon"
                  class="icon icon__user"
                >
              </a>
            {% endif %}

            <a href="{{ routes.cart_url }}" class="header__cart-link" aria-label="Shopping cart">
              {% if cart.item_count > 0 %}
                <span class="cart-count">{{ cart.item_count }}</span>
              {% endif %}
              <img
                src="{{ 'shopping-bag.svg' | asset_url }}"
                alt="Cart icon"
                class="icon icon__cart"
              >
            </a>
          </div>
        </div>
      </div>
      <div class="header__inner-bottom">
        <!-- Main navigation -->
        <nav class="header__navigation" role="navigation" aria-label="Main navigation">
          {% render 'header-menu', menu_handle: section.settings.menu %}
        </nav>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "select",
      "id": "menu_position",
      "label": "Menu position",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 0,
      "max": 500,
      "step": 20,
      "unit": "px",
      "label": "Logo width",
      "default": 200
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "label": "Mobile logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Utilities"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "Show language selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/region selector",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ]
}
{% endschema %}

{% style %}
  .header {
    background-color: var(--color-background-2, #333);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    color: var(--color-text, #222);
  }

  .header__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    display: flex;
    flex-direction: column;
    min-height: 80px;
  }

  .header__inner-top {
    display: flex;
  }

  .header__inner-left {
    flex: 1;
  }

  .header__inner-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .header__inner-bottom {
    display: flex;
    padding-top: 1rem;
    justify-content: {{ section.settings.menu_position }};
  }

  .header__logo-link {
    display: inline-block;
  }

  .header__logo-link:hover {
    opacity: 0.8;
  }

  .header__icons {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.6rem;
  }

  .header__icons a {
    color: var(--color-text, #222);
  }

  .header__icons a:hover {
    color: var(--color-text-hover, #800020);
  }

  .header__icons .icon {
    width: 1.5rem;
    height: 1.5rem;
    display: inline-block;
    position: relative;
    cursor: pointer;
  }

  .header__language-selector,
  .header__country-selector {
    position: relative;
  }

  .chevron::after {
    content: '';
    position: absolute;
    right: 6px;
    top: -4px;
    bottom: 0;
    margin: auto;
    transform: rotate(45deg);
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    width: 6px;
    height: 6px;
    pointer-events: none;
  }

  .header__language-selector select,
  .header__country-selector select {
    background: transparent;
    border: none;
    outline: none;
    box-shadow: none;
    padding: 0.4rem 1.0rem 0.4rem 0.4rem;
    cursor: pointer;
    color: inherit;
    font-size: 14px;
    font-family: inherit;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  .header__language-selector select:hover,
  .header__country-selector select:hover {
    color: var(--color-text-hover, #800020);
    background-color: rgba(0, 0, 0, 0.04);
  }

  .header__language-selector option,
  .header__country-selector option {
    color: var(--color-text, #222);
    background-color: var(--color-background-1, #d6d6d6);
  }

  .header__language-selector option:hover,
  .header__country-selector option:hover {
    color: var(--color-text-hover, #800020);
    background-color: rgba(0, 0, 0, 0.04);
  }

  @media (max-width: 1200px) {
    .header .container {
      padding: 0 1rem;
    }
    .header .header__inner-left {
      flex: 0;
    }
  }

  .header__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 1001;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 3px;
    background-color: #333;
    margin: 5px 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    border-radius: 1px;
  }

  @media (max-width: 768px) {
    .header__menu-toggle {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .header__inner-top {
      flex-wrap: wrap;
    }

    .header__inner-bottom {
      order: 3;
      width: 100%;
    }

    .header__navigation {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: white;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      z-index: 1000;
      padding: 1rem;
    }

    .header__navigation.active {
      display: block;
    }

    .header {
      position: relative;
    }
  }
{% endstyle %}
