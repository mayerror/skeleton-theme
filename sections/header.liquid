<header class="header full-width">
  <div class="container">
    <div class="header__inner">
      <!-- Mobile menu toggle -->
      <button class="header__menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger"></span>
        <span class="hamburger"></span>
        <span class="hamburger"></span>
      </button>
      <div class="header__inner-top">
        <div class="header__inner-left">
          {% if section.settings.logo_position == 'left' %}
            {% if section.settings.logo != blank %}
              <img
                src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                alt="{{ section.settings.logo.alt | escape }}"
                width="{{ section.settings.logo_width }}"
                height="{{ section.settings.logo.height }}"
                class="header__logo-image"
              >
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-center">
          {% if section.settings.logo_position == 'center' %}
            {% if section.settings.logo != blank %}
              <img
                src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                alt="{{ section.settings.logo.alt | escape }}"
                width="{{ section.settings.logo_width }}"
                height="{{ section.settings.logo.height }}"
                class="header__logo-image"
              >
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
        </div>
        <div class="header__inner-right">
          {% if section.settings.logo_position == 'right' %}
            {% if section.settings.logo != blank %}
              <img
                src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                alt="{{ section.settings.logo.alt | escape }}"
                width="{{ section.settings.logo_width }}"
                height="{{ section.settings.logo.height }}"
                class="header__logo-image"
              >
            {% else %}
              <p>{{ shop.name | link_to: routes.root_url }}</p>
            {% endif %}
          {% endif %}
          <!-- Header icons -->
          <div class="header__icons">
            {% if section.settings.show_language_selector %}
              <div class="header__language-selector">
                {% comment %} Language selector would go here {% endcomment %}
                <select aria-label="Language selector">
                  {% for locale in shop.published_locales %}
                    <option
                      value="{{ locale.iso_code }}"
                      {% if locale.iso_code == cart.locale.iso_code %}
                        selected
                      {% endif %}
                    >
                      {{ locale.name }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endif %}

            {% if section.settings.show_country_selector %}
              <div class="header__country-selector">
                {% comment %} Country selector would go here {% endcomment %}
                <select aria-label="Country/region selector">
                  <option value="US" selected>United States</option>
                  <option value="CA">Canada</option>
                  <option value="GB">United Kingdom</option>
                </select>
              </div>
            {% endif %}

            {% if section.settings.show_account and shop.customer_accounts_enabled %}
              <a href="{{ routes.account_url }}" aria-label="Account" class="header__account-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-account" viewBox="0 0 18 19">
                  <path fill="currentColor" fill-rule="evenodd" d="M6 4.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-4a4 4 0 1 0 0 8 4 4 0 0 0 0-8m5.58 12.15c1.12.82 1.83 2.24 1.91 4.85H1.51c.08-2.6.79-4.03 1.9-4.85C4.66 11.75 6.5 11.5 9 11.5s4.35.26 5.58 1.15M9 10.5c-2.5 0-4.65.24-6.17 1.35C1.27 12.98.5 14.93.5 18v.5h17V18c0-3.07-.77-5.02-2.33-6.15-1.52-1.1-3.67-1.35-6.17-1.35" clip-rule="evenodd"></path>
                </svg>
              </a>
            {% endif %}

            <a href="{{ routes.cart_url }}" class="header__cart-link" aria-label="Shopping cart">
              {% if cart.item_count > 0 %}
                <span class="cart-count">{{ cart.item_count }}</span>
              {% endif %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-cart-empty" viewBox="0 0 40 40">
                <path fill="currentColor" fill-rule="evenodd" d="M15.75 11.8h-3.16l-.77 11.6a5 5 0 0 0 4.99 5.34h7.38a5 5 0 0 0 4.99-5.33L28.4 11.8zm0 1h-2.22l-.71 10.67a4 4 0 0 0 3.99 4.27h7.38a4 4 0 0 0 4-4.27l-.72-10.67h-2.22v.63a4.75 4.75 0 1 1-9.5 0zm8.5 0h-7.5v.63a3.75 3.75 0 1 0 7.5 0z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="header__inner-bottom">
        <!-- Main navigation -->
        <nav class="header__navigation" role="navigation" aria-label="Main navigation">
          {% render 'header-menu', menu_handle: section.settings.menu %}
        </nav>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "select",
      "id": "menu_position",
      "label": "Menu position",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 0,
      "max": 500,
      "step": 20,
      "unit": "px",
      "label": "Logo width",
      "default": 200
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "label": "Mobile logo position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "header",
      "content": "Utilities"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "Show language selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/region selector",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ]
}
{% endschema %}

{% style %}
  .header {
    background-color: var(--color-background-2, #333);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    color: var(--color-text, #222);
  }

  .header__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    display: flex;
    flex-direction: column;
    min-height: 80px;
  }

  .header__inner-top {
    display: flex;
  }

  .header__inner-left {
    flex: 1;
  }

  .header__inner-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .header__inner-bottom {
    display: flex;
    padding-top: 1rem;
    justify-content: {{ section.settings.menu_position }};
  }

  .header__logo {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .header__logo h1 {
    color: --primary-color;
    font-size: 1.8rem;
  }

  .header__icons {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.6rem;
  }

  .header__icons a {
    color: var(--color-text, #222);
  }

  .header__icons svg {
    width: 22px;
    height: 22px;
  }

  .header__icons .icon {
    position: relative;
    margin-left: 20px;
    cursor: pointer;
  }

  .header__language-selector,
  .header__country-selector {
      position: relative;
  }

  .header__language-selector::after,
  .header__country-selector::after {
      content: '';
      position: absolute;
      right: 6px;
      top: -3px;
      bottom: 0;
      margin: auto;
      transform: rotate(45deg);
      border-right: 1px solid currentColor;
      border-bottom: 1px solid currentColor;
      width: 6px;
      height: 6px;
      pointer-events: none;
  }

  .header__language-selector select,
  .header__country-selector select {
      background: transparent;
      border: none;
      outline: none;
      box-shadow: none;
      padding: 5px 22px 5px 8px;
      cursor: pointer;
      color: inherit;
      font-size: 14px;
      font-family: inherit;
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
  }

    /* .header__icons .icon .badge {
      position: absolute;
      top: -4px;
      right: -8px;
      background-color: --primary-color;
      color: white;
      border-radius: 50%;
      width: 18px;
      height: 18px;
      font-size: 0.7rem;
      display: flex;
      align-items: center;
      justify-content: center;
    } */

    .header__main-menu {
      flex: 2;
    }

    .header__main-menu ul {
      display: flex;
      list-style: none;
      justify-content: center;
    }

    .header__main-menu ul li {
      margin: 0 15px;
    }

    .header__main-menu ul li a {
      text-decoration: none;
      color: var(--color-text, #222);
      font-weight: 500;
      transition: color 0.3s ease;
    }

    .header__main-menu ul li a:hover {
      color: --primary-color;
    }

    @media (max-width: 1200px) {
      .header .container {
        padding: 0 1rem;
      }
      .header .header__inner-left {
        flex: 0;
      }
      .header .header__logo {
        justify-content: flex-start;
      }
    }

    .header__menu-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px;
      z-index: 1001;
    }

    .hamburger {
      display: block;
      width: 24px;
      height: 3px;
      background-color: #333;
      margin: 5px 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
      border-radius: 1px;
    }

    @media (max-width: 768px) {
      .header__menu-toggle {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .header__inner-top {
        flex-wrap: wrap;
      }

      .header__inner-bottom {
        order: 3;
        width: 100%;
      }

      .header__navigation {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: white;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1000;
        padding: 1rem;
      }

      .header__navigation.active {
        display: block;
      }

      .header {
        position: relative;
      }
    }
{% endstyle %}
