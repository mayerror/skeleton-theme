{% comment %} Declare the menu setting from parent section {% endcomment %}
{%- assign menu_handle = menu_handle | default: section.settings.menu -%}
{%- assign menu = linklists[menu_handle] -%}

{% comment %} Only render if a menu is selected {% endcomment %}
{% if menu != blank %}
  <menu class="header__menu-list">
    {% for link in menu.links %}
      {% assign is_active = false %}

      {% if link.current or link.active %}
        {% assign is_active = true %}
      {% endif %}
      <li class="header__menu-item">
        {% if link.links == blank %}
          <a
            href="{{ link.url }}"
            class="header__menu-link {% if is_active %}header__menu-item-link--active{% endif %}"
          >
            {{- link.title -}}
          </a>
        {% else %}
          <a
            href="{{ link.url }}"
            class="header__menu-link chevron {% if is_active %}header__menu-item-link--active{% endif %}"
          >
            {{- link.title -}}
          </a>
          <ul class="header-submenu">
            {% for child_link in link.links %}
              <li class="header-submenu-item">
                <a href="{{ child_link.url }}" class="header-submenu-link">{{ child_link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </menu>
{% endif %}

<style>
  .header__menu-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
  }

  .header__menu-item {
    position: relative;
  }

  .header__menu-item .chevron {
    padding-right: 1.2rem;
  }

  .header__menu-link {
    padding: 0.2rem 0.3rem;
    position: relative;
    display: inline-block;
    text-decoration: none;
    color: #333;
    font-weight: 500;
    transition: color 0.3s ease;
    border-radius: 4px;
    transition: background-color 0.25s ease;
  }

  .header__menu-link.header__menu-item-link--active {
    font-weight: 700;
    color: #222;
    text-decoration: none;
    background: none;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.05); /* едва заметный объём */
  }

  .header__menu-link:hover {
    color: var(--color-text-hover, #800020);
    background-color: rgba(0, 0, 0, 0.04);
  }

  .header__menu-link:active {
    text-decoration: underline;
    background-color: rgba(0, 0, 0, 0.04);
  }

  .header-submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background-color: white;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border-radius: 0.25rem;
    min-width: 200px;
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 1000;
  }

  .header__menu-item:hover .header-submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header-submenu-item {
    margin: 0;
  }

  .header-submenu-link {
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
    color: #333;
    transition: background-color 0.3s ease;
  }

  .header-submenu-link:hover {
    background-color: #f5f5f5;
    color: var(--color-text-hover, #800020);
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .header__menu-list {
      flex-direction: column;
      gap: 0;
    }

    .header-submenu {
      position: static;
      box-shadow: none;
      background-color: #f9f9f9;
      opacity: 1;
      visibility: visible;
      transform: none;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .header-submenu.active {
      max-height: 300px;
    }

    .header-submenu-link {
      padding-left: 2rem;
    }
  }
</style>
